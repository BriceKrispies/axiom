# Rust / Cargo
/target/
**/target/
**/*.rs.bk
*.pdb

# Cargo lock for libraries (keep for binaries/workspaces — comment out if undesired)
# Cargo.lock

# WebAssembly build artifacts
/pkg/
**/pkg/
/dist/
**/dist/
*.wasm

# Packaged single-game bundles (scripts/package_app.py output)
/dist-app/
/dist-workspace/

# Vendored, built TypeScript SDK copied into a demo's web/ by `make netplay-build`
# (the netplay demo now lives under the merged gallery's web/netplay/).
**/web/vendor/
**/web/**/vendor/

# axiom-sound tool staging output (`<app>/assets/audio/<id>.mp3` + manifest.json).
# The shipped copy lives in the app's own `web/`; this staging dir is regenerable
# (and, for realtime-rendered sounds, non-deterministic).
**/assets/audio/

# .NET build output (scoped to examples/ so it never matches Rust `src/bin/`)
examples/**/bin/
examples/**/obj/

# Agent-bridge offscreen render output (frames/<tick>.png)
/frames/
wasm-pack.log

# Python tooling caches (scripts/)
__pycache__/
*.pyc

# Node (web/editor tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/

# IDE / editor
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.fleet/
.zed/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Env / secrets
.env
.env.*
!.env.example

# Logs / coverage / profiling
*.log
coverage/
*.profraw
*.profdata
flamegraph.svg
perf.data*

# Mutation testing output (cargo-mutants)
mutants.out/
mutants.out.old/
mutants-out*/

# Cloned upstream repos kept locally as read-only reference (e.g. bevyengine/bevy
# for the ECS gap analysis in docs/ecs-gap-analysis.md). Never part of the build.
/reference/

# Local agent / tooling state
.claude/settings.local.json

# Playwright controller daemon state (browser logs, screenshots, command log)
scripts/.playwright-controller/
scripts/.localhost-servers/

# tools/axiom-sound cache: gitignored lossless WAV render intermediates
tools/axiom-sound/.axiom-cache/

/screenshots