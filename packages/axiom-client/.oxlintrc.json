{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  // Axiom @axiom/client static-analysis gate. The TS-native counterpart of the
  // Rust spine's clippy/dylint + engine_no_branching laws. EVERY category is an
  // error and maxWarnings is 0, so any finding fails the run. Type-aware rules
  // run through tsgolint (typescript-go, TS 7). See STATIC_ANALYSIS.md.
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "restriction": "error",
    "nursery": "error"
  },
  "options": {
    "typeAware": true,
    "maxWarnings": 0
  },
  // The SDK runs in the browser; tests run in Node. Declaring the environments
  // gives no-undef the right global set (WebSocket, WebTransport, RTCPeerConnection,
  // fetch, EventTarget, setInterval, ...). This is environment configuration, not
  // a rule relaxation.
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "jsPlugins": [{ "name": "eslint-js", "specifier": "oxlint-plugin-eslint" }],
  "rules": {
    // The ONE rule disabled under "maximal", and only because it is a TypeScript
    // type-system impossibility, not a code-shape we could bend to: this SDK is
    // fundamentally a binary byte codec, so almost every function takes a
    // `Uint8Array` (or `DataView`). TypeScript has no readonly typed-array type;
    // `Readonly<Uint8Array>` still exposes the mutating methods (`set`, `fill`,
    // `copyWithin`, `sort`), so the rule still fires, and the only readonly
    // alternative (`readonly number[]`) would destroy both the binary contract
    // (it must mirror the Rust `axiom-net-protocol` wire bytes) and performance.
    // There is no code change that satisfies this rule for byte buffers — so per
    // CLAUDE.md's "genuinely un-fixable -> documented decision", it is disabled
    // here with justification rather than silently suppressed at call sites.
    "typescript/prefer-readonly-parameter-types": "off",

    // The Branchless Law for TypeScript: the no-restricted-syntax analogue of the
    // Rust engine_no_branching dylint. Every control-flow branch is banned.
    "eslint-js/no-restricted-syntax": [
      "error",
      { "selector": "IfStatement", "message": "Branchless Law: no `if`. Use a table index `[b, a][Number(cond)]` or an iterator combinator. See docs/ts-sdk-hardening.md." },
      { "selector": "ConditionalExpression", "message": "Branchless Law: no ternary `?:`. Select with a lookup table or arithmetic. See docs/ts-sdk-hardening.md." },
      { "selector": "SwitchStatement", "message": "Branchless Law: no `switch`. Dispatch through a record/Map keyed by the discriminant. See docs/ts-sdk-hardening.md." },
      { "selector": "ForStatement", "message": "Branchless Law: no `for`. Use map/forEach/reduce/from over the iterable. See docs/ts-sdk-hardening.md." },
      { "selector": "ForInStatement", "message": "Branchless Law: no `for...in`. Iterate Object.keys/entries with array combinators. See docs/ts-sdk-hardening.md." },
      { "selector": "ForOfStatement", "message": "Branchless Law: no `for...of`. Use map/forEach/reduce over the iterable. See docs/ts-sdk-hardening.md." },
      { "selector": "WhileStatement", "message": "Branchless Law: no `while`. Express the loop as an iterator/fold. See docs/ts-sdk-hardening.md." },
      { "selector": "DoWhileStatement", "message": "Branchless Law: no `do...while`. Express the loop as an iterator/fold. See docs/ts-sdk-hardening.md." },
      { "selector": "LogicalExpression[operator='&&']", "message": "Branchless Law: no `&&` short-circuit. Use `&` when the RHS is pure, or combinators for guards. See docs/ts-sdk-hardening.md." },
      { "selector": "LogicalExpression[operator='||']", "message": "Branchless Law: no `||` short-circuit. Use `|` when the RHS is pure, or combinators. See docs/ts-sdk-hardening.md." },
      { "selector": "LogicalExpression[operator='??']", "message": "Branchless Law: no `??`. Default through a value transform, not a short-circuit. See docs/ts-sdk-hardening.md." },
      { "selector": "ChainExpression", "message": "Branchless Law: no optional chaining `?.`. Make presence explicit through a value transform. See docs/ts-sdk-hardening.md." }
    ]
  },
  "overrides": [
    {
      // Tests keep their branches — the Branchless Law exempts tests exactly as
      // the Rust engine_no_branching lint does. Tests stay under the correctness,
      // suspicious, perf, and type-aware safety rules (the bugs that matter), but
      // the production-ergonomics pedantic/style/restriction rules that are
      // hostile to readable test code are relaxed — byte-vector literals
      // (no-magic-numbers), conventional short names (id-length), fixture array
      // access (no-non-null-assertion), etc. This matches the Rust reality, where
      // clippy lints tests but does not enforce naming/magic-number style on them.
      "files": ["test/**/*.ts"],
      "rules": {
        "eslint-js/no-restricted-syntax": "off",
        "eslint/capitalized-comments": "off",
        "eslint/func-style": "off",
        "eslint/id-length": "off",
        "eslint/init-declarations": "off",
        "eslint/max-lines": "off",
        "eslint/max-lines-per-function": "off",
        "eslint/max-statements": "off",
        "eslint/no-inline-comments": "off",
        "eslint/no-magic-numbers": "off",
        "eslint/no-plusplus": "off",
        "eslint/no-undefined": "off",
        "eslint/no-void": "off",
        "eslint/sort-imports": "off",
        "oxc/no-rest-spread-properties": "off",
        "typescript/no-floating-promises": "off",
        "typescript/no-non-null-assertion": "off",
        "unicorn/number-literal-case": "off",
        "unicorn/prefer-at": "off",
        "unicorn/prefer-spread": "off"
      }
    },
    {
      // The platform edge: webtransport.ts/webrtc.ts are the browser-API boundary
      // (async WebTransport streams + WebRTC negotiation). This is the SDK's
      // analogue of the Rust spine's host/windowing layers, which sit outside the
      // strict spine laws. Only the rules that the async-DOM boundary genuinely
      // fights are scoped off here, documented; every general-quality rule
      // (naming, sorting, complexity, return types, no-null, ...) still applies.
      // These files are also coverage-exempt (browser-only, verified via the
      // Playwright path) — see scripts/ts-gate + STATIC_ANALYSIS.md.
      //   - branch ban / optional chaining: async stream + negotiation control flow
      //   - async-await / await-in-loop: the transports ARE async; stream reads
      //     are inherently sequential (an unbounded stream, not Promise.all-able)
      //   - no-unsafe-*: the browser WebTransport/WebRTC/JSON APIs are `any`-typed
      "files": ["src/webtransport.ts", "src/webrtc.ts", "src/build-transport.ts"],
      "rules": {
        "eslint-js/no-restricted-syntax": "off",
        "eslint/no-await-in-loop": "off",
        "oxc/no-async-await": "off",
        "oxc/no-optional-chaining": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-type-assertion": "off"
      }
    }
  ]
}
