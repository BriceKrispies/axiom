{
  "name": "@axiom/client",
  "version": "0.1.0",
  "description": "Axiom multiplayer browser SDK: a tiny WebSocket client that speaks the axiom-net-protocol wire format. Server-authoritative — clients send intents, apply snapshots. No framework, no prediction/rollback/reconnect (yet).",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "node --test \"test/**/*.test.ts\"",
    "typecheck": "tsgo --noEmit",
    "build": "tsgo -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-exclude=\"test/**\" \"test/**/*.test.ts\"",
    "gate": "npm run typecheck && npm run lint && npm run coverage"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "oxlint": "1.70.0",
    "oxlint-plugin-eslint": "1.70.0",
    "oxlint-tsgolint": "0.23.0"
  }
}
