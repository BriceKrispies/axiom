{
  "name": "@axiom/game",
  "version": "0.1.0",
  "description": "Axiom Phaser-style TypeScript authoring SDK: write a whole game in TypeScript (createGame, onFixedUpdate, onRender, the Scene shell) while the deterministic native core (apps/axiom-game-runtime, wasm) runs the fixed-step loop. The stable authoring boundary every subsystem spec projects through.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "node --test \"test/**/*.test.ts\"",
    "typecheck": "tsgo --noEmit",
    "build": "tsgo -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-exclude=\"test/**\" --test-coverage-exclude=\"src/raf-loop.ts\" --test-coverage-exclude=\"src/wasm-bridge.ts\" --test-coverage-exclude=\"src/wasm-host.ts\" \"test/**/*.test.ts\"",
    "gate": "npm run typecheck && npm run lint && npm run coverage"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "oxlint": "1.70.0",
    "oxlint-plugin-eslint": "1.70.0",
    "oxlint-tsgolint": "0.23.0"
  }
}
